# Ver DEPLOY.md, seção 3, para a descrição completa de cada variável.

ENVIRONMENT=development
LOG_LEVEL=INFO

# Comentado = usa o padrão sqlite:///<raiz-do-repo>/database/app.db
# DATABASE_URL=

JWT_SECRET_KEY=dev-secret-key-troque-em-producao
JWT_REFRESH_SECRET_KEY=dev-refresh-secret-key-troque-em-producao
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

CORS_ALLOWED_ORIGINS=http://localhost:5173

# Comentado = usa o padrão <raiz-do-repo>/imports
# STORAGE_DIR=
